# .env.example - Template for environment variables
# Copy this file to .env and fill in your values

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# BACKEND
# ==========================================
BACKEND_PORT=4000

# ==========================================
# DATABASE — Microsoft SQL Server
# ==========================================
# For Docker development (matches docker-compose.yml)
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong@Passw0rd
MSSQL_DATABASE=factorymap
MSSQL_TRUST_CERT=true
# Set MSSQL_ENCRYPT=true when connecting to Azure SQL or a server with a valid cert
MSSQL_ENCRYPT=false

# For local development (outside Docker), change MSSQL_HOST to localhost

# ==========================================
# ITSM INTEGRATION (READ-ONLY!)
# ==========================================
ITSM_MODE=mock
# Options: 'mock' for development, 'real' for production

# Mock ITSM (for development)
ITSM_MOCK_API_URL=http://localhost:4000/mock-itsm

# Real ITSM (for production - leave empty in development)
ITSM_REAL_API_URL=
ITSM_API_KEY=
ITSM_WEB_URL=

# Sync interval (milliseconds) - how often to check ITSM for updates
ITSM_SYNC_INTERVAL=300000

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=CHANGE_THIS_TO_SECURE_SECRET

# ==========================================
# MAINTENANCE ALERTS
# ==========================================
# SMTP — fill in to enable email notifications
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=factory-map@yourcompany.com
SMTP_PASS=CHANGE_THIS_SMTP_PASSWORD
SMTP_FROM=factory-map@yourcompany.com

# Microsoft Teams Incoming Webhook URL — fill in to enable Teams notifications
# Create one in Teams: channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=

# ==========================================
# LDAP / Active Directory (optional)
# Set LDAP_ENABLED=true to activate LDAP login
# ==========================================
LDAP_ENABLED=false
LDAP_URL=ldap://your-dc.example.com:389
LDAP_BIND_DN=CN=svc-factorymap,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=CHANGE_THIS_LDAP_PASSWORD
LDAP_SEARCH_BASE=OU=Users,DC=example,DC=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_TLS_ENABLED=false
# Role assigned to newly provisioned LDAP users: admin | operator | viewer
LDAP_DEFAULT_ROLE=viewer

# ==========================================
# AZURE AD / OIDC (optional, future)
# Set AZURE_AD_ENABLED=true to activate Azure login
# ==========================================
AZURE_AD_ENABLED=false
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/callback

# ==========================================
# CORS
# ==========================================
# Origin the browser frontend is served from. Must be set in production.
# In development this is typically http://localhost:5174 (Vite/CRA dev server).
CORS_ORIGIN=http://localhost:5174

# ==========================================
# FRONTEND
# ==========================================
REACT_APP_API_URL=http://localhost:4000/api

# Public base URL — used to build the URL embedded inside asset QR codes.
# When left empty the app falls back to window.location.origin, which works
# correctly if users open the app via the server's real IP or hostname.
# Set this to your public hostname in production so QR codes work from any
# network (e.g. REACT_APP_PUBLIC_BASE_URL=http://factorymap.yourcompany.com).
REACT_APP_PUBLIC_BASE_URL=