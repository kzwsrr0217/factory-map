# .env.example - Template for environment variables
# Copy this file to .env and fill in your values

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# BACKEND
# ==========================================
BACKEND_PORT=5000

# ==========================================
# DATABASE
# ==========================================
MONGODB_URI=mongodb://mongo:27017/factorymap
MONGODB_USER=factorymap_user
MONGODB_PASSWORD=CHANGE_THIS_PASSWORD

# ==========================================
# ITSM INTEGRATION (READ-ONLY!)
# ==========================================
ITSM_MODE=mock
# Options: 'mock' for development, 'real' for production

# Mock ITSM (for development)
ITSM_MOCK_API_URL=http://localhost:5000/mock-itsm

# Real ITSM (for production - leave empty in development)
ITSM_REAL_API_URL=
ITSM_API_KEY=
ITSM_WEB_URL=

# Sync interval (milliseconds) - how often to check ITSM for updates
ITSM_SYNC_INTERVAL=300000

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=CHANGE_THIS_TO_SECURE_SECRET

# ==========================================
# FRONTEND
# ==========================================
REACT_APP_API_URL=http://localhost:5000/api