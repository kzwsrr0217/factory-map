{
  "name": "factory-map-backend",
  "version": "1.0.0",
  "description": "Factory Map Backend API - TypeScript + Express + MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "seed": "ts-node src/scripts/seed-mssql.ts",
    "seed:docker": "docker-compose exec backend npm run seed",
    "test": "jest --runInBand --forceExit --passWithNoTests",
    "test:watch": "jest --watch",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/data-source.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "runInBand": true,
    "forceExit": true,
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/src/__tests__/helpers/jestEnv.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/helpers/jestSetup.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "keywords": [
    "factory-map",
    "asset-management",
    "itsm",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@types/ldapjs": "^3.0.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "morgan": "^1.10.0",
    "mssql": "^11.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
